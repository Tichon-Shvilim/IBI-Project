# ============================================
# IBI AI Management — Environment Variables
# ============================================
# Copy to .env.local עבור פיתוח מקומי, Vercel env vars עבור production.

# ----- Database (Vercel Postgres / Neon) -----
# pooled connection, משמש ב-runtime
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require&pgbouncer=true"
# direct connection, משמש עבור prisma migrate
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ----- NextAuth v5 -----
# npx auth secret להפקה
AUTH_SECRET="replace-with-openssl-rand-base64-32"
# URL של ההרצה. production: https://ibi-ai.vercel.app
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ----- Google OAuth (Gmail + Drive + Calendar) -----
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----- Anthropic (Claude) -----
# https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ----- WhatsApp Cloud API (Phase 1C) -----
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_TO_NUMBER=""

# ----- Vercel Blob (upload מסמכים) -----
BLOB_READ_WRITE_TOKEN=""

# ----- Upstash Ratelimit (אופציונלי) -----
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ----- Seed -----
# כתובת המייל של נתי, משמש ב-prisma seed ליצירת user+agent ראשוני
SEED_USER_EMAIL="natimanshori@gmail.com"
